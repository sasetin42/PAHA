rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdminEmail() {
      return request.auth != null &&
        'email' in request.auth.token &&
        request.auth.token.email in ['admin@paha.ph', 'admin@gmail.com', 'support@paha.ph', 'cesartrongcoso@gmail.com', 'admin@paha.com', 'john@paha.com', 'carl.smcc24@gmail.com'];
    }

    function isAdmin() {
      return request.auth != null && 
        (isSuperAdminEmail() ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('adminRole', '') in ['admin', 'super_admin'] ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true)));
    }

    // --- Public Read, Auth Write ---

    match /members/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /committee_members/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /former_officers/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /partners/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /pages/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /systemSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /membership_plans/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- Public Create, Auth Read/Manage ---

    match /contact_messages/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /membership_applications/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /accreditation_submissions/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // --- Auth Only ---

    match /users/{docId} {
      // Users can read their own doc; super admins can read any user doc
      allow read: if request.auth != null
                  && (request.auth.uid == docId || isSuperAdminEmail() || (request.auth.uid != docId && isAdmin()));
      allow create: if request.auth != null
                    && (request.auth.uid == docId || isSuperAdminEmail() || (request.auth.uid != docId && isAdmin()));
      allow update: if request.auth != null
                    && (request.auth.uid == docId || isSuperAdminEmail() || (request.auth.uid != docId && isAdmin()));
      allow delete: if request.auth != null
                    && (request.auth.uid == docId || isSuperAdminEmail() || (request.auth.uid != docId && isAdmin()));
    }

    match /membership_payments/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    match /convention_registrations/{docId} {
      allow read, write: if request.auth != null;
    }

    match /event_registrations/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }

    match /accreditation_applications/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }

    match /admin_notifications/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }

    match /member_notifications/{docId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
    }

    match /users/{userId}/representatives/{docId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /paymentGatewaySettings/{docId} {
      // Allow any authenticated user to read (sensitive keys are masked by the Cloud Function)
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /paycoolsChannels/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /paymentTransactions/{docId} {
      allow read, write: if request.auth != null;
    }

    match /paymentWebhookLogs/{docId} {
      allow read, write: if isAdmin();
    }

    match /adminAuditLogs/{docId} {
      allow read, write: if isAdmin();
    }

    // Each chat doc is one conversation "topic" thread, owned by whichever
    // member's uid is on it (multiple topics can exist per member over time).
    match /chats/{chatId} {
      allow read, update: if request.auth != null && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if request.auth != null && (isAdmin() || request.resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read, create, update: if request.auth != null &&
          (isAdmin() || get(/databases/$(database)/documents/chats/$(chatId)).data.uid == request.auth.uid);
        allow delete: if isAdmin();
      }
    }

    // Fallback: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}